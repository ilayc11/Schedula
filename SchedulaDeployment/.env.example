# Notification service Telegram linking
TELEGRAM_BOT_NAME=Schedula_BotBot
TELEGRAM_LINK_TOKEN_TTL_SECONDS=900

# Backend to notification_service routing
NOTIFICATION_SERVICE_BASE_URL=http://notification:8000
NOTIFICATION_QUEUE_NAME=notifications_queue

# Apprise URLs (comma-separated). Include Telegram here, e.g.:
# APPRISE_URLS=tgram://<bot_token>/<chat_id>
APPRISE_URLS=

# Email sender configuration for notification_service (Apprise mailto://)
# For Gmail, use your app password. You can use either "schedulaemail" or
# "schedulaemail@gmail.com" as EMAIL_SENDER_USERNAME.
EMAIL_SENDER_USERNAME=
EMAIL_SENDER_APP_PASSWORD=
EMAIL_SENDER_DOMAIN=gmail.com
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_MODE=starttls
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Schedula

# Cloudflare Named Tunnel (stable URL)
CLOUDFLARED_TUNNEL_TOKEN=

# RabbitMQ Configuration
RABBITMQ_URL=amqp://rabbitmq:rabbitmq@rabbitmq:5672/

# Database Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=schedula
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/schedula
NOTIFICATION_DATABASE_POOL_MIN_SIZE=2
NOTIFICATION_DATABASE_POOL_MAX_SIZE=10

# Ollama Configuration
OLLAMA_KEEP_ALIVE=-1
